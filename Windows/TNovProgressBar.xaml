<Window x:Class="TNovCommon.TNovProgressBar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TNovCommon"
        MaxHeight="140" MaxWidth="400" MinHeight="80" MinWidth="400"
        WindowStartupLocation="CenterScreen" 
        AllowsTransparency="True" Background="Transparent" 
        ResizeMode="NoResize" WindowStyle="None" Topmost="true">


    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
Background="White"
BorderBrush="#FF008E43"
BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Заголовок окна -->
            <Border Grid.Row="0"
                Height="30" CornerRadius="12 12 0 0"
                Background="#FF008E43" 
                MouseDown="Border_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}" 
Content="✕" Click="closeButton_Click"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle3}" 
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Обработка элементов" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                </StackPanel>
            </Border>

            <!-- Строка с информацией -->
            <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <TextBlock Name="info" x:FieldModifier="public" />
            </StackPanel>

            <!-- Прогресс-бар и счётчик -->
            <ProgressBar Grid.Row="2" 
                     Name="TNov_ProgressBar" 
                     x:FieldModifier="public"
                     Margin="12.5 5 12.5 12.5" 
                     Value="0" 
                     BorderBrush="#CCCCCC"/>

            <StackPanel Grid.Row="2" Margin="12.5 5 12.5 12.5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <TextBlock Name="value" x:FieldModifier="public" Margin="5,0"/>
                <TextBlock Text="/" Margin="5,0"/>
                <TextBlock Name="maxvalue" x:FieldModifier="public" Margin="5,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>