<Window x:Class="TNovCommon.ElementsTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TNovCommon"
        Title="Необработанные элементы" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
                AllowsTransparency="True"
Background="Transparent" 
ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:InverseConverter x:Key="InverseConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
          ResizeBorderThickness="5"
          GlassFrameThickness="0"
          CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
    Background="White"
    BorderBrush="#FF008E43"
    BorderThickness="1">
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="30 px"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel VerticalAlignment="Center"  Grid.Row="0"  >
                <Border Height="30" CornerRadius="12 12 0 0"
    Background="#FF008E43" 
    VerticalAlignment="Top"
    MouseDown="Border_MouseDown">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource RoundButtonStyle}" 
Command="{Binding CloseCommand}" Content="✕"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Style="{StaticResource RoundButtonStyle3}" 
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <TextBlock Text="Данные элементы не были обработаны:" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                    </StackPanel>
                    
                </Border>
            </StackPanel>

            <TreeView Grid.Row="1" ItemsSource="{Binding Categories}" Margin="10 10 10 0">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type local:CategoryNode}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsChecked}" Margin="2"/>
                            <TextBlock Text="{Binding CategoryName}" Margin="2"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type local:FamilyNode}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsChecked}" Margin="2"/>
                            <TextBlock Text="{Binding FamilyName}" Margin="2"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type local:TypeNode}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsChecked}" Margin="2"/>
                            <TextBlock Text="{Binding TypeName}" Margin="2"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                    <DataTemplate DataType="{x:Type local:ElementNode}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsChecked}" Margin="2"/>
                            <TextBlock Text="{Binding Id}" Margin="2"/>
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,10,10">
                <Button Style="{StaticResource CustomButtonStyle}" Content="Открыть логи" Click="Button_Click" MinHeight="25" Width="100" Margin="5 5 30 5"/>
                <Button Style="{StaticResource CustomButtonStyle}" Content="Выбрать" Command="{Binding SelectCommand}" MinHeight="25" Width="100" Margin="5"/>
                <Button Style="{StaticResource CustomButtonStyle}" Content="Завершить" Command="{Binding CloseCommand}" MinHeight="25" Width="100" Margin="5"/>
            </StackPanel>
        </Grid>

    </Border>
    </Window>