<Window x:Class="TNovCommon.VersionHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История версий" 
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
                AllowsTransparency="True"
Background="Transparent"
        
ResizeMode="NoResize" 
WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
          ResizeBorderThickness="5"
          GlassFrameThickness="0"
          CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
    Background="White"
    BorderBrush="#FF008E43"
    BorderThickness="1">
        <Grid>
            <Border Height="30" CornerRadius="12 12 0 0"
            Background="#FF008E43" 
            VerticalAlignment="Top"
            MouseDown="Border_MouseDown">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource RoundButtonStyle}" 
Content="✕" Click="CloseButton_Click"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button Style="{StaticResource RoundButtonStyle3}" 
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                <TextBlock Text="История версий" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
            </StackPanel>
        </Border>
        <Border Margin="0,30,0,0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                   Text="{Binding Path=HoleGroupName, StringFormat='Группа: {0}', TargetNullValue='Группа не указана'}" 
                   FontWeight="Bold" Margin="0,0,0,8"/>

                <TextBox Grid.Row="1" 
                 Text="{Binding MEPCommentsHistory}" 
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 AcceptsReturn="True"/>

                <Button Grid.Row="2"  Style="{StaticResource CustomButtonStyle}"
                Content="Закрыть" 
                Width="80" 
                HorizontalAlignment="Right" 
                Margin="0,8,0,0"
                Click="CloseButton_Click"/>
            </Grid>
        </Border>
        </Grid>
    </Border>
</Window>