<UserControl x:Class="TNovCommon.SyncJournalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovCommon"
             mc:Ignorable="d"
             Height="Auto" Width="Auto">
    
    <Border>
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Журнал синхронизаций модели" 
                   HorizontalAlignment="Center" Margin="10" FontSize="14" FontWeight="Bold" />

            <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">
                <TextBlock Name="text1" Margin="5" Text="" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Grid>
    </Border>

</UserControl>
