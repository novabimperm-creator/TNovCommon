<Window x:Class="TNovCommon.AppVersionWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovCommon"
             mc:Ignorable="d" Width="500"
        d:DataContext="{d:DesignInstance local:AppVersionViewModel}"
           WindowStartupLocation="CenterScreen" 
                                                           AllowsTransparency="True"
Background="Transparent" ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
          ResizeBorderThickness="5"
          GlassFrameThickness="0"
          CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
Background="White"
BorderBrush="#FF008E43"
BorderThickness="1">

        <Grid>



            <Border Height="30" CornerRadius="12 12 0 0"
    Background="#FF008E43" 
    VerticalAlignment="Top"
    MouseDown="Border_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}" 
Click="acceptButton_Click" Content="✕"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle2}" 
Click="HelpButton_Click" Content="?"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Настройки TNov" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                </StackPanel>

            </Border>

            <!-- Основное содержимое -->
            <Border Margin="0,30,0,0">

                <StackPanel VerticalAlignment="Center" Margin="5">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Name="text1" Text="{Binding headtxt}" Margin="5" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Имя пользователя:" Margin="5" TextWrapping="Wrap" />
                        <TextBlock Name="userName" Text="{Binding userName}" Margin="5" TextWrapping="Wrap" />
                        <TextBlock Text="Отдел:" Margin="5" TextWrapping="Wrap" />
                        <TextBlock Name="userDep" Text="{Binding userDep}" Margin="5" TextWrapping="Wrap" />
                        <TextBlock Text="Роль:" Margin="5" TextWrapping="Wrap" />
                        <TextBlock Name="userDepRole" Text="{Binding userDepRole}" Margin="5" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Настройки логов:" Margin="5" TextWrapping="Wrap" FontWeight="Bold" />

                        <CheckBox BorderBrush="#CCCCCC" x:Name="checkBox1" IsThreeState="False" IsChecked="{Binding extendedLogs}" Content="Записывать расширенные логи"  Margin="5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Настройки предупреждений о синхронизации*:" Margin="5" TextWrapping="Wrap" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Сценарий:" Margin="0 0 5 0" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding synclist}"
    SelectedItem="{Binding Path=sync1, Mode=TwoWay}"
    SelectedIndex = "0"
    MinWidth="191"
/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="*изменятся после перезапуска программы" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Margin="5" Width="250" TextWrapping="Wrap">
                <Hyperlink NavigateUri="{Binding url}" RequestNavigate="Hyperlink_RequestNavigate">
                    Открыть инструкцию по работе функций</Hyperlink>
                        </TextBlock>
                    </StackPanel>


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource CustomButtonStyle}" Content="Применить" x:Name="acceptButton" IsCancel="True" IsDefault="True" Click="acceptButton_Click" MinWidth="90" MinHeight="25" Margin="0 10 0 0" />
                    </StackPanel>
                </StackPanel>


            </Border>
        </Grid>
    </Border>
</Window>
