<UserControl x:Class="TNovCommon.ChecklistControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TNovCommon"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:ChecklistControlViewModel}"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BooleanToStrikeConverter x:Key="BooleanToStrikeConverter"/>
            <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Чек-лист (задачник)"
                   Style="{StaticResource PanelHeaderStyle}"
                   HorizontalAlignment="Center"
                   FontSize="14"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBoxStyle}"
                     VerticalContentAlignment="Center"
                     Margin="0"/>
            <Button Content="Добавить"
                    Command="{Binding AddCommand}"
                    Grid.Column="1"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="8,0,0,0"
                    Padding="14,8"/>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <TextBlock Text="Создатель:"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding Creators}"
                      SelectedItem="{Binding SelectedCreator}"
                      Style="{StaticResource DarkComboBoxStyle}"
                      MinWidth="180"
                      Margin="0"/>
        </StackPanel>

        <Border Grid.Row="3"
                BorderBrush="{StaticResource SelectedBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,8,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ItemsView}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ChangeCardStyle}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.EditTitleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox IsChecked="{Binding IsChecked}"
                                              Style="{StaticResource DarkCheckBoxStyle}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>

                                    <Border Grid.Column="1"
                                            Width="40"
                                            Height="40"
                                            Margin="0,0,8,0"
                                            Background="{StaticResource BgBrush}"
                                            BorderBrush="{StaticResource TreeToggleBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Cursor="Hand"
                                            Visibility="{Binding PhotoFileName, Converter={StaticResource StringToVisibilityConverter}}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.ViewPhotoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Image Source="{Binding PhotoImageSource}"
                                               Stretch="Uniform"
                                               Margin="2"/>
                                    </Border>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding Title}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource JournalModuleStyle}"
                                                   TextDecorations="{Binding IsChecked, Converter={StaticResource BooleanToStrikeConverter}}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayDate}"
                                                       Style="{StaticResource JournalDateStyle}"
                                                       Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding Creator}"
                                                       Style="{StaticResource JournalDateStyle}"
                                                       Margin="8,3,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="📋"
                                                Command="{Binding DataContext.PastePhotoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,6"
                                                MinWidth="32"
                                                Margin="0,0,4,0"/>
                                        <Button Content="🗑"
                                                Command="{Binding DataContext.DeletePhotoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,6"
                                                MinWidth="32"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding PhotoFileName, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        <Button Content="✕"
                                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,6"
                                                MinWidth="32"
                                                Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
