<Window x:Class="TNovCommon.TextEditorWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovCommon"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Редактирование JSON-данных" FontWeight="Bold"/>
        <TextBox x:Name="JsonTextBox" Grid.Row="1" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" MinHeight="200"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Click="Save_Click" Margin="5"/>
            <Button Content="Загрузить с сервера" Click="Load_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
