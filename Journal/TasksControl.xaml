<UserControl x:Class="TNovCommon.TasksControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Name="HeadPanel" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock x:Name="UserNamePrefixTextBlock"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"/>
                <TextBlock x:Name="UserNameTextBlock"
                           Margin="5,0,0,0"
                           Foreground="White"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="UserRolePrefixTextBlock"
                           Margin="12,0,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"/>
                <TextBlock x:Name="UserRoleTextBlock"
                           Margin="5,0,0,0"
                           Foreground="White"
                           FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="Журнал выдачи заданий"
                       Style="{StaticResource PanelHeaderStyle}"
                       HorizontalAlignment="Center"
                       FontSize="14"/>
        </StackPanel>

        <Grid x:Name="TableContainer"
              Grid.Row="1"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
                <TextBlock Text="Проект:"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="ProjectComboBox"
                          Style="{StaticResource DarkComboBoxStyle}"
                          MinWidth="150"
                          Margin="0"
                          IsEditable="True"
                          IsTextSearchEnabled="True"/>
                <TextBlock Text="Модель:"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="12,0,8,0"/>
                <ComboBox x:Name="ModelComboBox"
                          Style="{StaticResource DarkComboBoxStyle}"
                          MinWidth="150"
                          Margin="0"
                          IsEditable="True"
                          IsTextSearchEnabled="True"/>
                <Button Content="Очистить фильтры"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,6"
                        Click="ClearFiltersButton_Click"/>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      x:Name="HoleGrid"
                      Style="{StaticResource DarkDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource DarkDataGridCellStyle}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource DarkDataGridRowStyle}">
                        <Setter Property="ToolTip" Value="{Binding MEPComments}"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Имя группы">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Имя группы"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="FilterHoleGroup"
                                             Width="120"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Margin="0,4,0,0"
                                             TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding HoleGroupName}"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Версия">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TaskVersion}"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="5,0,5,0"/>
                                    <Button Content="..."
                                            ToolTip="История версий"
                                            Width="24"
                                            Height="20"
                                            FontSize="12"
                                            Padding="0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="VersionHistoryButton_Click"
                                            Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Дата выдачи"
                                        Binding="{Binding TaskDate}"
                                        ElementStyle="{StaticResource DarkDataGridTextElementStyle}"/>

                    <DataGridTemplateColumn Header="Выдал">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Выдал"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="FilterInitiator"
                                             Width="100"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Margin="0,4,0,0"
                                             TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Initiator}"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Модель КР"
                                        Binding="{Binding STModelName}"
                                        ElementStyle="{StaticResource DarkDataGridTextElementStyle}"/>

                    <DataGridTemplateColumn Header="Статус КР">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Статус КР"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBox x:Name="FilterSTStatus"
                                             Width="100"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Margin="0,4,0,0"
                                             TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding STStatus}"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
