<UserControl x:Class="TNovCommon.AutoCheckControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovCommon"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:AutoCheckControlViewModel}"
             Height="Auto" Width="Auto">
    <UserControl.Resources>
        <local:BooleanToStrikeConverter x:Key="BooleanToStrikeConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <!-- Стиль с полным шаблоном -->
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Убираем SystemColors -->
                        <ControlTemplate.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" 
                                 Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" 
                                 Color="Transparent"/>
                        </ControlTemplate.Resources>

                        <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- Прямое указание цвета -->
                                <Setter TargetName="border" 
                            Property="Background" 
                            Value="#FF008E43"/>
                                <!-- Цвет заголовка -->
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" 
                            Property="Background" 
                            Value="#FF008E43"/>
                                <!-- Темнее -->
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" 
                            Property="Opacity" 
                            Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="White" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Строка фильтра -->
                <RowDefinition Height="Auto"/>
                <!-- Строка добавления -->
                <RowDefinition Height="*"/>
                <!-- Список -->
            </Grid.RowDefinitions>

            

            <!-- Панель добавления задачи -->
            <Grid Grid.Row="0" Margin="15,0,15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock FontWeight="Bold"
HorizontalAlignment="Center" Text="Автоматические проверки" FontSize="14" Margin="10"/>
                    <Button Content="Обновить проверки" Command="{Binding UpdCommand}" 
                        Height="25" Style="{StaticResource CustomButtonStyle}"/>
                </StackPanel>
                
            </Grid>
            <!-- Фильтр по создателю -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,5,15,5">
                <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding Statuses}" 
              SelectedItem="{Binding SelectedStatus}" 
              Width="150" 
              VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Список задач с привязкой к отсортированному и отфильтрованному представлению -->
            <Border Grid.Row="2" BorderBrush="#F5F5F5" BorderThickness="0,1,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,5">
                    <ItemsControl ItemsSource="{Binding ItemsView}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="15,5" Padding="10" Background="White" 
        BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="0,0,8,0" IsEnabled="False">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" FontSize="13" Foreground="#333"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayDate}" FontSize="10" Foreground="#AAA" Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding Creator}" FontSize="10" Foreground="#AAA" Margin="5,3,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                                            <Button Content="Выбрать элементы" Command="{Binding DataContext.SelectElemsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource CustomButtonStyle}" Margin="0,0,5,0" Height="25" MinWidth="25"
                                                    Visibility="{Binding ElemIds, Converter={StaticResource StringToVisibilityConverter}}"/>
                                            <Button Content="Открыть лог" Command="{Binding DataContext.OpenLogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource CustomButtonStyle}" Margin="0,0,5,0" Height="25" MinWidth="25"
                                                    Visibility="{Binding ElemIds, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>

</UserControl>
