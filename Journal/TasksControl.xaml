<UserControl x:Class="TNovCommon.TasksControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Height="Auto" Width="Auto">
    <Grid Background="WhiteSmoke">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <!-- Верхняя панель: имя пользователя -->
        <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,0,0,5" Name="HeadPanel">
            <!-- Имя пользователя и роль -->
            <StackPanel Orientation="Horizontal" Margin="0,5,0,5" VerticalAlignment="Center">
                <TextBlock x:Name="UserNamePrefixTextBlock" 
               FontWeight="SemiBold" Foreground="Gray"/>
                <TextBlock x:Name="UserNameTextBlock" Margin="5,0,0,0"
               FontWeight="Bold" Foreground="Black"/>
                <TextBlock x:Name="UserRolePrefixTextBlock" Margin="5,0,0,0"
               FontWeight="SemiBold" Foreground="Gray"/>
                <TextBlock x:Name="UserRoleTextBlock" Margin="5,0,0,0"
               FontWeight="Bold" Foreground="Black"/>
            </StackPanel>
            <TextBlock FontWeight="Bold"
           HorizontalAlignment="Center" Text="Журнал выдачи заданий" FontSize="14" Margin="10 5 10 10"/>
        </StackPanel>

        <!-- Нижняя часть: фильтры + таблица (занимает всё оставшееся место) -->
        <Grid x:Name="TableContainer" Grid.Row="1" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Фильтры проекта и модели -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Проект:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="ProjectComboBox" Width="150"
                          IsEditable="True" IsTextSearchEnabled="True"/>
                <TextBlock Text="Модель:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <ComboBox x:Name="ModelComboBox" Width="150"
                          IsEditable="True" IsTextSearchEnabled="True"/>
                <Button Content="Очистить фильтры" VerticalAlignment="Center"
            Margin="10,0,0,0" Padding="8,3"
            Background="#E0E0E0" BorderBrush="#CCCCCC" BorderThickness="1"
            Foreground="#333" FontSize="12" FontWeight="SemiBold"
            Cursor="Hand" Click="ClearFiltersButton_Click"/>
            </StackPanel>

            <!-- Таблица с автоматической прокруткой -->
            <DataGrid Grid.Row="1" x:Name="HoleGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Resources>
                    <!-- Стиль строки с ToolTip, привязанным к свойству MEPComments -->
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="ToolTip" Value="{Binding MEPComments}" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Имя группы">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Имя группы" FontWeight="Bold"/>
                                    <TextBox x:Name="FilterHoleGroup" Width="120"
                                             TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding HoleGroupName}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Версия" Binding="{Binding TaskVersion}"/>
                    <DataGridTextColumn Header="Дата выдачи" Binding="{Binding TaskDate}" SortDirection="Descending"/>

                    <DataGridTemplateColumn Header="Выдал">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Выдал" FontWeight="Bold"/>
                                    <TextBox x:Name="FilterInitiator" Width="100"
                                             TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Initiator}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Модель КР" Binding="{Binding STModelName}"/>

                    <DataGridTemplateColumn Header="Статус КР">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Статус КР" FontWeight="Bold"/>
                                    <TextBox x:Name="FilterSTStatus" Width="100"
                                             TextChanged="Filter_TextChanged"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding STStatus}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>